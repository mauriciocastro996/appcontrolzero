<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center">

        <!-- Logo Shield -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@color/color_amarillo"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@color/white"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_shield_check"
                    android:contentDescription="@string/shield_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ControlZero"
                    android:textSize="10sp"
                    android:textColor="#333630"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- TITULO -->
        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ControlZero"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#333630"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistema de Control de Alcoholemia Laboral"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <!-- Error Message -->
        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#F44336"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"/>

        <!-- CAMPO USUARIO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <EditText
                android:id="@+id/etUsuario"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Correo Electrónico"
                android:inputType="textEmailAddress"
                android:padding="15dp"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="#333333"
                android:textColorHint="#999999"/>

        </androidx.cardview.widget.CardView>

        <!-- CAMPO PASSWORD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:padding="15dp"
                android:background="@null"
                android:textSize="16sp"
                android:textColor="#333333"
                android:textColorHint="#999999"/>

        </androidx.cardview.widget.CardView>

        <!-- BOTON LOGIN -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIngresar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="INGRESAR"
            android:textStyle="bold"
            android:textColor="#333630"
            android:textSize="18sp"
            app:backgroundTint="#F9B21C"
            android:layout_marginBottom="16dp"
            android:elevation="4dp"/>

        <!-- BOTON BIOMETRICO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBiometrico"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Continuar con Huella / Face ID"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#333630"
            android:layout_marginBottom="24dp"
            android:elevation="4dp"/>

        <!-- Social Login Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/color_gris_claro"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="O continuar con"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginHorizontal="16dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/color_gris_claro"/>

        </LinearLayout>

        <!-- Social Login Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleLogin"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Google"
                android:textColor="#333630"
                android:textSize="14sp"
                app:backgroundTint="#FFFFFF"
                app:icon="@android:drawable/ic_menu_search"
                app:iconPadding="8dp"
                app:iconTint="#333630"
                app:strokeColor="#CCCCCC"
                app:strokeWidth="1dp"
                android:elevation="2dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebookLogin"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Facebook"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                app:backgroundTint="#0D5CB6"
                app:icon="@android:drawable/ic_menu_share"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                android:elevation="2dp"/>

        </LinearLayout>

        <!-- CREAR USUARIO -->
        <TextView
            android:id="@+id/tvCrearUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear Usuario"
            android:textColor="#F9B21C"
            android:textStyle="bold"
            android:textSize="17sp"
            android:layout_marginBottom="10dp"/>

        <!-- OLVIDO PASSWORD -->
        <TextView
            android:id="@+id/tvOlvido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Olvidaste tu contraseña?"
            android:textColor="#666666"
            android:textSize="16sp"/>

    </LinearLayout>

</ScrollView>